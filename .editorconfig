# EditorConfig — единые правила оформления файлов для всех редакторов.
# Документация: https://editorconfig.org
root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space
indent_size = 2

# Python — PEP 8: 4 пробела.
[*.py]
indent_size = 4

# Makefile требует табы.
[Makefile]
indent_style = tab

# Markdown: trailing spaces могут означать перенос строки, не трогаем.
[*.md]
trim_trailing_whitespace = false
