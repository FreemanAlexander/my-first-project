# .env.example — шаблон переменных окружения
#
# В этом файле — ТОЛЬКО имена ключей и пустые значения.
# Реальные значения (токены, connection strings, секреты) НИКОГДА
# не коммитим: реальный .env живёт локально и в secrets хостинга
# (Vercel для лендинга, провайдер для бота, Yandex Cloud в prod).
#
# В .gitignore: `.env`, `.env.*` игнорируются, `.env.example` — whitelisted.
#
# Источник правды по архитектуре: docs/backend-decision.md, api.md,
# db/schema.md, docs/bot-flows.md.


# === Telegram-бот ===

# Токен бота, выдаётся @BotFather. Используется только Python-ботом
# (aiogram) на сервере. В логи и сообщения не попадает никогда.
BOT_TOKEN=

# Whitelist админов через запятую: telegram_id админов
# (например: 12345678,87654321). Источник прав для админских действий
# в боте — см. docs/bot-flows.md, раздел «Авторизация».
ADMIN_IDS=


# === База данных ===

# PostgreSQL connection string.
# Sandbox (DB_MODE=sandbox): ведёт в Supabase — без реальных ПДн.
# Production (DB_MODE=production): ведёт в Yandex Cloud Managed PostgreSQL
# или другой RU-hosted Postgres.
# Используется и Next.js Route Handlers, и Python-ботом.
DATABASE_URL=


# === Связь web ↔ бот ===

# Базовый URL лендинга.
#   local       → http://localhost:3000
#   preview     → Vercel preview URL
#   production  → https://<домен>
# Используется ботом для deep links на лендинг и в Next.js
# для абсолютных ссылок и CORS.
WEB_BASE_URL=


# === Окружение и режим compliance ===

# Окружение приложения. Допустимые значения:
#   local | preview | sandbox | production
# Влияет на баннер «тестовая среда», уровень логирования,
# строгость проверок 152-ФЗ.
APP_ENV=

# Режим БД, плагнутой в DATABASE_URL. Допустимые значения:
#   sandbox     → Supabase, реальные ПДн запрещены, принимаем только синтетику
#   production  → RU-hosted Postgres; требуется PD_STORAGE_REGION=ru
# Используется приложением для safety-check на старте.
DB_MODE=

# Регион физического хранения ПДн. Допустимые значения:
#   ru | non_ru
# 152-ФЗ требует первичную запись и хранение ПДн граждан РФ
# на серверах в РФ. В production обязательно `ru`, иначе
# приложение должно отказаться стартовать.
PD_STORAGE_REGION=

# Версия текста согласия на обработку ПДн (формат: YYYY-MM-DD,
# например: 2026-05-18). Должна совпадать с consent_policy_version
# из формы заявки (см. api.md, POST /api/leads, код CONSENT_REQUIRED).
# При изменении текста согласия — поднимаем версию; старые согласия
# не «обновляются» задним числом, остаются под старой версией.
CONSENT_POLICY_VERSION=


# === Внутренние секреты ===

# Общий секрет для заголовка X-Bot-Webhook-Secret в POST /api/bot/notify
# (см. api.md, опциональный webhook backend → бот).
# Случайная строка ≥ 32 символов. В логи и callback_data не попадает.
INTERNAL_BOT_NOTIFY_SECRET=
