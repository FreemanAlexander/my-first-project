# Шаблон env для docker compose Postgres.
# Скопируй в docker/postgres/.env и подставь свои значения.
# Реальный .env коммитить НЕЛЬЗЯ — он в .gitignore.

# Имя приложения-пользователя БД.
POSTGRES_USER=pml_app

# Пароль приложения. Сгенерируй случайную строку >= 32 символов
# в менеджере паролей. Не вводить в чат, не коммитить.
POSTGRES_PASSWORD=

# Имя dev/staging-базы.
POSTGRES_DB=pml_dev
